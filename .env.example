# Provedor de IA: none | gpt | gemini | claude | ollama
LLM_PROVIDER=none

# Idioma da interface e das respostas do Jarvis.
# Valores suportados: pt-BR, en-US
JARVIS_LANGUAGE=pt-BR

# Modo de depuração. true mostra o que foi ouvido e respondido na própria tela.
JARVIS_DEBUG=false

OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (IA local). Requer Ollama instalado em https://ollama.com
# e o modelo baixado com `ollama pull qwen2.5:3b`.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Spotify (PKCE — client_id público, sem client_secret).
# Registre um app gratis em https://developer.spotify.com/dashboard,
# adicione http://127.0.0.1:8765/callback como Redirect URI e cole o Client ID aqui.
SPOTIFY_CLIENT_ID=
