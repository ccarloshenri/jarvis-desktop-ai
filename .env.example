# Idioma da interface e das respostas do Jarvis.
# Valores suportados: pt-BR, en-US
JARVIS_LANGUAGE=pt-BR

# Modo de depuracao. true mostra o que foi ouvido e respondido na propria tela.
JARVIS_DEBUG=false

# LLM provider. Values: groq / openai / anthropic / gemini / lm_studio.
# Missing credentials falls back to lm_studio (local) — log says so.
JARVIS_LLM_PROVIDER=groq

# OpenAI (optional). Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
JARVIS_OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional). Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
JARVIS_ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Gemini (optional). Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
JARVIS_GEMINI_MODEL=gemini-2.0-flash

# Local LM Studio (fallback). Launch LM Studio with any OpenAI-compatible
# model loaded and keep the server running.
JARVIS_LM_STUDIO_URL=http://localhost:1234/v1
JARVIS_LM_STUDIO_MODEL=qwen2.5-3b-instruct

# Streaming da resposta do LLM. true = a fala do Jarvis comeca assim que o
# modelo produz a primeira frase (latencia -1 a -2s em respostas longas).
# false volta pro modo bloqueante (espera o JSON completo antes de falar).
JARVIS_LLM_STREAMING=true

# Piper persistente (pool de processos pre-aquecidos). true elimina o custo
# de load da voz (~150-300ms) por chunk de fala. false volta pro modo
# spawn-por-chunk (lento, mas mais simples pra debug).
JARVIS_PIPER_PERSISTENT=true

# TTS provider em ordem de qualidade:
#   elevenlabs = MELHOR (voz nivel humano, multilingue PT/EN, ~10k chars/mes gratis)
#   groq       = bom (playai-tts, soa um pouco "locutor", SO EM INGLES)
#   piper      = local gratis (voz Faber PT-BR, mais robotica mas funciona sem internet)
JARVIS_TTS_PROVIDER=elevenlabs

# ElevenLabs — configurar primeiro em https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Voice ID. Ache mais vozes em https://elevenlabs.io/app/voice-library
#   onwK4e9ZLuTAKqWW03F9 — Daniel, britanico grave (Jarvis oficial)
#   pNInz6obpgDQGcFmaJgB — Adam, americano grave
#   29vD33N1CtxCmqQRPOHJ — Drew, americano middle-aged
#   AZnzlk1XvdvUeBnXmlld — Domi, feminina nitida
JARVIS_ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
# Model. eleven_multilingual_v2 = melhor qualidade, suporta PT e EN.
# eleven_turbo_v2_5 = 3x mais rapido, qualidade levemente menor.
JARVIS_ELEVENLABS_MODEL=eleven_multilingual_v2

# Groq TTS (fallback). Se escolher groq, troque JARVIS_LANGUAGE=en-US
# porque playai-tts so fala ingles.
JARVIS_GROQ_TTS_MODEL=playai-tts
# Vozes Groq masculinas graves: Fritz-PlayAI, Atlas-PlayAI, Mason-PlayAI,
# Briggs-PlayAI, Basil-PlayAI, Calum-PlayAI.
# Femininas: Celeste-PlayAI, Arista-PlayAI, Quinn-PlayAI, Indigo-PlayAI.
JARVIS_GROQ_TTS_VOICE=Fritz-PlayAI

# Endpointer de fim-de-fala. "silero" usa uma rede neural (Silero VAD,
# ~1MB ONNX em models/vad/silero_vad.onnx) que fecha a captura em ~350ms
# de silencio real em vez dos 800ms do RMS. Requer baixar o modelo uma
# vez: rode scripts/fetch_silero_vad.ps1. Fallback automatico pra "rms"
# se o arquivo nao existir.
JARVIS_VAD_BACKEND=silero
# Threshold do Silero VAD (0.0-1.0). 0.5 e o padrao do upstream. Abaixe
# pra 0.3 se o Jarvis corta sua fala no meio em voz baixa; aumente pra
# 0.7 em ambientes barulhentos se ele espera demais pra fechar.
JARVIS_VAD_THRESHOLD=0.5

# Speech-to-text: groq (cloud, Whisper large-v3-turbo, ~100ms, gratis),
# whisper (local, CPU, mais lento e menos preciso), google (fallback).
# Se escolher "groq" e nao setar GROQ_API_KEY, cai automatico pra whisper.
JARVIS_STT_PROVIDER=whisper

# API key do Groq pra STT na nuvem. Pegue gratis em
# https://console.groq.com/keys (14400 requests/dia, 20 RPM no free tier).
# A acuracia em PT-BR com nomes em ingles ("Lana Del Rey", "Taylor Swift")
# e MUITO melhor que Whisper small local. Com key configurada, coloque
# JARVIS_STT_PROVIDER=groq acima.
GROQ_API_KEY=
# Modelo do Groq. whisper-large-v3-turbo e o default (melhor equilibrio
# precisao/latencia). whisper-large-v3 e um pouco mais preciso mas ~2x
# mais lento.
JARVIS_GROQ_STT_MODEL=whisper-large-v3-turbo
# Modelo do Whisper: tiny, base, small, medium, large-v3. 'small' e o
# melhor equilibrio entre precisao em PT-BR e latencia (~1.5-2s em CPU).
# 'base' e quase 2x mais rapido mas erra mais palavra-chave/wake-word.
JARVIS_WHISPER_MODEL=small
# Device: auto, cpu, cuda.
JARVIS_WHISPER_DEVICE=auto
# Compute type: int8 (CPU, rapido), int8_float16 (GPU leve), float16 (GPU).
JARVIS_WHISPER_COMPUTE=int8
# Beam size do decoder Whisper. 1 = greedy (mais rapido, erra mais nomes
# proprios e verbos). 3 = busca em 3 caminhos (~30% mais lento, bem mais
# preciso em PT-BR). 5+ raramente ajuda em comandos curtos.
JARVIS_WHISPER_BEAM_SIZE=3

# Wake-word detection. Quando true (e openwakeword instalado), o Jarvis
# fica em modo passivo e so transcreve audio depois de detectar a palavra
# de despertar. Cortou ~80% do uso de CPU em ambientes com fala ambiente
# e elimina os turnos "fantasma" de 8s perdidos com transcricoes ignoradas.
JARVIS_WAKE_WORD=true
# Modelo de wake-word do openwakeword. "hey_jarvis" e o unico pre-treinado
# oficial com "jarvis" no nome. Apesar do nome, voce NAO precisa dizer
# "hey" — so falar "Jarvis" ja dispara no threshold abaixo. O "hey" no
# nome vem do dataset de treino em ingles; em PT-BR o score fica menor
# mas consistentemente acima de 0.15 em fala natural.
JARVIS_WAKE_WORD_MODEL=hey_jarvis
# Threshold de confianca (0.0-1.0). Aumente se houver falsos positivos
# (Jarvis dispara sem voce chamar); diminua se ele esta perdendo o
# wake-word. 0.15 e calibrado para falantes de PT-BR dizendo so "Jarvis"
# em tom natural. Se nao detectar, rode com JARVIS_WAKE_WORD_DEBUG=true
# pra ver os scores em tempo real e ajuste baseado nos peaks reais.
JARVIS_WAKE_WORD_THRESHOLD=0.15
# Debug: loga todo score > 0.05 imediatamente. Use pra calibrar o
# threshold acima contra a sua voz e microfone. Deixe false em uso
# normal (gera muito log).
JARVIS_WAKE_WORD_DEBUG=false

# Debug de transcricao ruim: salva CADA captura como WAV. Default e
# logs/audio_dumps/. Os WAVs ocupam ~30KB cada e NAO sao limpos
# automaticamente — limpe manualmente de tempos em tempos. Para desligar
# completamente, use JARVIS_AUDIO_DUMP_DIR=off.
JARVIS_AUDIO_DUMP_DIR=

# Spotify (PKCE — client_id publico, sem client_secret).
# Registre um app gratis em https://developer.spotify.com/dashboard,
# adicione http://127.0.0.1:8765/callback como Redirect URI e cole o Client ID aqui.
SPOTIFY_CLIENT_ID=
